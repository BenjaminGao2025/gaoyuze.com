---
import { getCollection } from 'astro:content';
import ArticleCard from '../components/ArticleCard.astro';
import BookCard from '../components/BookCard.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { languageLabels, siteConfig } from '../config';
import { getArticleLanguages, getCanonicalArticles, sortArticlesByDate } from '../utils/content';

const allArticles = await getCollection('articles', ({ data }) => !data.draft);
const recentArticles = sortArticlesByDate(getCanonicalArticles(allArticles)).slice(0, 3);
const books = (await getCollection('books')).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout>
  <section class="hero-section">
    <div class="hero-copy">
      <p class="eyebrow">Public mind · {siteConfig.since}</p>
      <h1>Gao Yuze</h1>
      <p class="lede">Long-term thoughts, books in progress, and the visible record of becoming more capable through writing.</p>
      <dl class="hero-facts">
        {siteConfig.stats.map((stat) => <div><dt>{stat.label}</dt><dd>{stat.value}</dd></div>)}
      </dl>
    </div>
    <figure class="hero-visual"><img src="/assets/mind-archive.svg" alt="Abstract paper field for Gao Yuze public mind archive" /></figure>
  </section>

  <section class="status-band" aria-label="Current status">
    <div><p>{siteConfig.current.label}</p><strong>{siteConfig.current.title}</strong><span>{siteConfig.current.detail}</span></div>
    <p>{siteConfig.statusLine.join(' · ')}</p>
  </section>

  <section class="section-block">
    <div class="section-heading"><p class="section-kicker">§ 01 · Articles</p><h2>The journal — thoughts kept in public</h2><a href="/articles/">All articles</a></div>
    <div class="article-grid">
      {recentArticles.map((article) => <ArticleCard article={article} languages={getArticleLanguages(article, allArticles).map((item) => languageLabels[item.lang] ?? item.lang)} />)}
    </div>
  </section>

  <section class="section-block">
    <div class="section-heading"><p class="section-kicker">§ 02 · Books</p><h2>The shelf — long projects in rotation</h2><a href="/books/">Open catalogue</a></div>
    <div class="book-grid">{books.slice(0, 4).map((book) => <BookCard book={book} />)}</div>
  </section>
</BaseLayout>
